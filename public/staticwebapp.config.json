{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.{css,js,mjs,json,png,gif,jpg,jpeg,svg,webp,ico,woff,woff2,ttf,eot,otf,wasm,map}"
    ]
  },
  "globalHeaders": {
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "X-Content-Type-Options": "nosniff"
  }
}
