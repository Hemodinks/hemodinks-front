{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://hemodinks.gestao-saude.tec.br/:path*",
      "permanent": true
    }
  ]
}
