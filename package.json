{
  "name": "hemodinks-front",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/write-otel-runtime-config.mjs",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node scripts/write-otel-runtime-config.mjs",
    "build": "tsc -b && vite build",
    "preanalyze": "node scripts/write-otel-runtime-config.mjs",
    "analyze": "tsc -b && vite build --mode analyze",
    "budget": "node scripts/check-bundle-budget.mjs",
    "audit:a11y": "playwright test --grep acessibilidade",
    "audit:lighthouse": "npm run build && lhci autorun --config=./lighthouserc.cjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@newrelic/browser-agent": "^1.316.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone-peer-dep": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation": "^0.219.0",
    "@opentelemetry/instrumentation-document-load": "^0.64.0",
    "@opentelemetry/instrumentation-fetch": "^0.219.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.63.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/react": "^10.57.0",
    "@tanstack/react-query": "^5.101.0",
    "@vitejs/plugin-react": "^5.1.1",
    "axios": "^1.18.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.555.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.1.8"
  }
}
